# BSC Testnet
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-2-s3.binance.org:8545
BSC_TESTNET_PRIVATE_KEY=

# BSC Mainnet
BSC_RPC_URL=https://bsc-dataseed.binance.org
BSC_PRIVATE_KEY=

# Etherscan / BscScan API key (for contract verification)
ETHERSCAN_API_KEY=

# AgenticCommerce (UUPS Proxy)
# ERC8183_ADDRESS: proxy address, populated after running scripts/deploy-commerce.ts
ERC8183_ADDRESS=0x8b121FEf5e1688B976D814003f05d9366F3Fa8A3

# ACP_IMPL_ADDRESS: implementation address (CREATE2 deterministic), populated after deploy
ACP_IMPL_ADDRESS=

# PAYMENT_TOKEN_ADDRESS: ERC-20 token used for job payments and evaluator bond
#   BSC Testnet default: mock U token (0xc70B...)
PAYMENT_TOKEN_ADDRESS=0xc70B8741B8B07A6d61E54fd4B20f22Fa648E5565

# APEXEvaluator (UUPS Proxy)
# APEX_EVALUATOR_ADDRESS: proxy address, populated after running scripts/deploy-evaluator.ts
APEX_EVALUATOR_ADDRESS=0x283d858244932664bd69eb7FE3b1587b84B14be8

# OOV3_EVALUATOR_IMPL_ADDRESS: implementation address (CREATE2 deterministic), populated after deploy
OOV3_EVALUATOR_IMPL_ADDRESS=

# OOV3_ADDRESS: UMA Optimistic Oracle V3 contract address on the target network
#   BSC Testnet: 0xFc5bb3e475cc9264760Cf33b1e9ea7B87942C709
OOV3_ADDRESS=0xFc5bb3e475cc9264760Cf33b1e9ea7B87942C709

# EVALUATOR_LIVENESS: seconds the UMA dispute window stays open before auto-resolution
#   Testnet recommendation: 1800 (30 min)
#   Mainnet recommendation: 7200+ (2 h) to allow time for human dispute
EVALUATOR_LIVENESS=1800

# INITIAL_BOND_DEPOSIT: amount of PAYMENT_TOKEN (in wei) pre-deposited into APEXEvaluator
#   to cover UMA dispute bonds. Each disputed job consumes one bond.
#   Default: 100 tokens with 18 decimals = 100000000000000000000
#   Set higher on mainnet if high dispute volume is expected.
INITIAL_BOND_DEPOSIT=100000000000000000000

# SKIP_BOND_DEPOSIT: set to true to skip the automatic bond deposit during deploy-evaluator.ts
#   Useful when: bond tokens must be sourced separately, or re-running on an already-funded contract
#   Default: false (deposit is performed automatically if bondBalance == 0)
SKIP_BOND_DEPOSIT=false
