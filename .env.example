# ────────────────── Network ──────────────────
BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545
BSC_MAINNET_RPC=https://bsc-dataseed.binance.org
ETHERSCAN_API_KEY=<your bscscan api key>

# ────────────────── Deployer ──────────────────
# EOA private key used for the initial deployment.
# After rotate-admin.ts, this key no longer holds admin privileges.
PRIVATE_KEY=0x...

# ────────────────── Token ──────────────────
# Payment token (USDT on BSC). Same for both networks; override per-env file if needed.
PAYMENT_TOKEN=0x...

# ────────────────── Governance ──────────────────
UPGRADE_SAFE_ADDR=0x...      # 2-of-3 Safe
OPS_SAFE_ADDR=0x...          # 2-of-3 Safe

# mainnet only — testnet leave blank / ignored
DEPLOY_TIMELOCK=false        # set to `true` on mainnet
TIMELOCK_DELAY=172800        # 48h in seconds

# Set by deploy scripts / rotate-admin:
# For testnet: DEFAULT_ADMIN_HOLDER = UPGRADE_SAFE_ADDR
# For mainnet: DEFAULT_ADMIN_HOLDER = TimelockController address (set after deploy-timelock.ts)
DEFAULT_ADMIN_HOLDER=0x...

# ────────────────── Deployed Addresses (filled after each deploy) ──────────────────
ERC8183_ADDRESS=0x...        # ACP proxy
ROUTER_ADDRESS=0x...
POLICY_ADDRESS=0x...

# ────────────────── Policy params ──────────────────
DISPUTE_WINDOW=259200        # 3 days
VOTE_QUORUM=3
INITIAL_VOTERS=0x...,0x...,0x...,0x...,0x...
POLICY_ADMIN=0x...           # initial deployer EOA; later rotated to OPS_SAFE_ADDR
ROUTER_ADMIN=0x...           # same as POLICY_ADMIN typically
